# Copy to `.env` and adjust. Never commit real secrets.
# This file configures the BACKEND only. API keys stay server-side and are
# never exposed to the frontend.

DATABASE_URL=sqlite+aiosqlite:///./council.db

# Providers — leave keys empty to fall back to the realistic MockProvider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COMPOSE2_API_KEY=

DEFAULT_OPENAI_MODEL=gpt-4o-mini
DEFAULT_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# manual: UI copy/export; api: call COMPOSE2_BASE_URL (placeholder contract)
COMPOSE2_MODE=manual
COMPOSE2_BASE_URL=

# Set true for a full offline demo / CI without any API keys.
# (The app also auto-falls back to mock answers when keys are missing.)
USE_MOCK_PROVIDERS=true

# Allowed browser origins for the API. Include the frontend URL(s).
# Docker: the frontend is served by nginx on http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

MAX_PROJECT_FILE_BYTES=512000
