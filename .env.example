# Copy to `.env` and adjust. Never commit real secrets.

DATABASE_URL=sqlite+aiosqlite:///./council.db

# Providers — leave keys empty to fall back to MockProvider for that agent
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COMPOSE2_API_KEY=

DEFAULT_OPENAI_MODEL=gpt-4o-mini
DEFAULT_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# manual: UI copy/export; api: call COMPOSE2_BASE_URL (placeholder contract)
COMPOSE2_MODE=manual
COMPOSE2_BASE_URL=

# Set true for offline demo / CI without API keys
USE_MOCK_PROVIDERS=false

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MAX_PROJECT_FILE_BYTES=512000
